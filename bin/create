#!/usr/bin/env bash
set -euo pipefail

PROJECT="${1:-}"
DOMAIN="_"
TYPE="static"

shift || true

while [ $# -gt 0 ]; do
  case "$1" in
    --domain)
      DOMAIN="${2:-}"
      shift 2
      ;;
    --type)
      TYPE="${2:-}"
      shift 2
      ;;
    *)
      echo "Unknown option: $1"
      exit 1
      ;;
  esac
done

if [ -z "$PROJECT" ]; then
  echo "Usage: shipyard create <project> [--domain example.com] [--type static|laravel|node]"
  exit 1
fi

if [[ ! "$PROJECT" =~ ^[a-zA-Z0-9_-]+$ ]]; then
  echo "Invalid project name. Use only letters, numbers, hyphen, and underscore."
  exit 1
fi

case "$TYPE" in
  static|laravel|node)
    ;;
  *)
    echo "Unsupported type: $TYPE"
    echo "Supported types: static, laravel, node"
    exit 1
    ;;
esac

PROJECT_DIR="/var/www/sites/$PROJECT"
CONFIG_FILE="/etc/deploy-sites/$PROJECT.conf"

NGINX_AVAILABLE="/etc/nginx/sites-available/$PROJECT"
NGINX_ENABLED="/etc/nginx/sites-enabled/$PROJECT"

TEMPLATE="/opt/shipyard/templates/nginx/$TYPE.conf"

if [ ! -f "$TEMPLATE" ]; then
  echo "Template not found: $TEMPLATE"
  exit 1
fi

if [ -e "$PROJECT_DIR" ]; then
  echo "Project directory already exists: $PROJECT_DIR"
  exit 1
fi

if [ -e "$CONFIG_FILE" ]; then
  echo "Config already exists: $CONFIG_FILE"
  exit 1
fi

mkdir -p "$PROJECT_DIR/releases"
mkdir -p "$PROJECT_DIR/shared"

cat > "$CONFIG_FILE" <<EOF
PROJECT_NAME="$PROJECT"
PROJECT_DIR="$PROJECT_DIR"
KEEP_RELEASES=5
TYPE="$TYPE"
HEALTH_CHECK_FILE="index.html"
DOMAIN="$DOMAIN"
EOF

sed \
  -e "s|{{PROJECT_NAME}}|$PROJECT|g" \
  -e "s|{{PROJECT_DIR}}|$PROJECT_DIR|g" \
  -e "s|{{DOMAIN}}|$DOMAIN|g" \
  "$TEMPLATE" > "$NGINX_AVAILABLE"

if [ ! -L "$NGINX_ENABLED" ]; then
  ln -s "$NGINX_AVAILABLE" "$NGINX_ENABLED"
fi

nginx -t
sudo systemctl reload nginx

echo ""
echo "✔ Project created successfully"
echo ""
echo "Project"
echo "  Name   : $PROJECT"
echo "  Type   : $TYPE"
echo "  Domain : $DOMAIN"
echo ""
echo "Paths"
echo "  Directory : $PROJECT_DIR"
echo "  Config    : $CONFIG_FILE"
echo "  Nginx     : $NGINX_AVAILABLE"
echo ""
echo "Next steps"
echo "  1. Point your domain DNS to this server"
echo "  2. Add your GitHub Actions deployment workflow"
echo "  3. Deploy with:"
echo "     shipyard deploy $PROJECT /tmp/artifact.tar.gz <release-id>"
