#!/usr/bin/env bash
set -euo pipefail

source /opt/shipyard/lib/config.sh

PROJECT="${1:-}"

if [ -z "$PROJECT" ]; then
  echo "Usage: shipyard ssl <project>"
  exit 1
fi

load_project_config "$PROJECT"

if [ -z "${DOMAIN:-}" ] || [ "$DOMAIN" = "_" ]; then
  echo "No valid DOMAIN found in project config."
  echo "Edit: /etc/deploy-sites/$PROJECT.conf"
  exit 1
fi

echo "Requesting SSL certificate for:"
echo "  $DOMAIN"

sudo certbot --nginx -d "$DOMAIN"
