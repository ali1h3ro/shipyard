#!/usr/bin/env bash
set -euo pipefail

source /opt/shipyard/lib/config.sh

PROJECT="${1:-}"

if [ -z "$PROJECT" ]; then
  echo "Usage: shipyard nginx <project>"
  exit 1
fi

load_project_config "$PROJECT"

DOMAIN="${DOMAIN:-_}"
TEMPLATE="/opt/shipyard/templates/nginx/${TYPE:-static}.conf"
NGINX_AVAILABLE="/etc/nginx/sites-available/$PROJECT"
NGINX_ENABLED="/etc/nginx/sites-enabled/$PROJECT"

if [ ! -f "$TEMPLATE" ]; then
  echo "Template not found: $TEMPLATE"
  exit 1
fi

sed \
  -e "s|{{PROJECT_NAME}}|$PROJECT_NAME|g" \
  -e "s|{{PROJECT_DIR}}|$PROJECT_DIR|g" \
  -e "s|{{DOMAIN}}|$DOMAIN|g" \
  "$TEMPLATE" | sudo tee "$NGINX_AVAILABLE" > /dev/null

if [ ! -L "$NGINX_ENABLED" ]; then
  sudo ln -s "$NGINX_AVAILABLE" "$NGINX_ENABLED"
fi

sudo nginx -t
sudo systemctl reload nginx

echo "Nginx config applied for: $PROJECT"
echo "Domain: $DOMAIN"
